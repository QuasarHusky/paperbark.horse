---
import PaperBlock from "$components/containers/PaperBlock.astro";
import Content from "$components/elements/Content.astro";
import Page from "$layouts/Page.astro";
---

<Page title="Discord" navigation={false}>
    <div class="dialog">
        <img class="dialog-image" src="/assets/discord-header.png" alt="" />
        <PaperBlock>
            <div class="dialog-inner">
                <div class="dialog-content">
                    <h1 class="title">Add me on Discord!</h1>
                    <Content theme="paper">
                        <ul>
                            <li>Open the Discord app</li>
                            <li>Go to your messages</li>
                            <li>Select "Add Friends"</li>
                            <li>Choose "Add by Username"</li>
                        </ul>
                    </Content>
                    <div class="discord-username">
                        <img src="/assets/icons/discord.svg" alt="" style="width: 2.2rem;" />
                        <span>QuasarHusky</span>
                    </div>
                    <Content theme="paper">
                        <p style="text-align: center;">
                            <a href="/">Go back</a>
                        </p>
                    </Content>
                </div>
            </div>
        </PaperBlock>
    </div>
</Page>

<style lang="scss">
    .dialog {
        min-height: 100svh;

        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;

        gap: 2rem;

        padding: 1rem;

        .dialog-image {
            width: 100%;
            max-width: 15rem;

            filter: var(--filter-shadow-medium);
        }

        .dialog-content {
            display: flex;
            flex-direction: column;
            align-items: center;

            gap: 0.5rem;
        }

        .title {
            font-size: 1.75em;
            font-weight: var(--font-semibold);
        }
    }

    .discord-username {
        display: flex;
        flex-direction: row;
        align-items: center;
        padding: 0.4rem 1rem;
        margin: 1rem 0;
        gap: 0.7rem;

        border: 0.1rem solid #444444;
        border-radius: 0.5rem;

        background-color: #222222;

        font-size: 1.6rem;
        font-weight: var(--font-medium);
        color: white;
    }

    .discord-username img {
        user-select: none;
    }
</style>
