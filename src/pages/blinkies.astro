<style lang="scss">
    .blinkie-grid,
    .stamps-grid,
    .buttons-grid {
        display: grid;
        justify-items: center;
        gap: 0.25rem;
    }

    .blinkie-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    }

    .stamps-grid {
        grid-template-columns: repeat(auto-fill, minmax(146px, 1fr));
    }

    .buttons-grid {
        grid-template-columns: repeat(auto-fill, minmax(146px, 1fr));
    }
</style>
