                    href="https://en.wikipedia.org/wiki/ISO_8601"
                />
                <Blinkie type="button" src="/blinkies/buttons/css-is-awesome.png" alt="CSS is awesome" />
            </div>
        </PaperBlock>
    </SimpleLayout>
