        </PaperBlock>
    </SimpleLayout>
</Page>

<style lang="scss">
    .blinkie-grid,
    .stamps-grid,
    .buttons-grid {
        display: grid;
        justify-items: center;
        gap: 0.5rem;

        img {
            width: 100%;
            object-fit: contain;
            image-rendering: pixelated;
        }

        a {
            display: flex;
            width: 100%;
        }
    }

    .blinkie-grid {
        grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));

        img {
            aspect-ratio: 300 / 40;
        }
    }

    .stamps-grid {
        grid-template-columns: repeat(auto-fill, minmax(146px, 1fr));

        img {
            aspect-ratio: 99 / 56;
        }
    }

    .buttons-grid {
        grid-template-columns: repeat(auto-fill, minmax(146px, 1fr));

        img {
            aspect-ratio: 88 / 31;
        }
    }
</style>
