                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/mouse-bites.gif"
                        alt="He needs mouse bites to live"
                        href="https://www.youtube.com/watch?v=ry-Z6_yfZoE"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/portal.gif" alt="Portal" />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/portal-2.gif" alt="Portal 2" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/stardew-valley.gif"
                        alt="Stardew Valley"
                    />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/terraria-player.gif"
                        alt="Terraria Player"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/the-sims-3.gif" alt="The Sims 3" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/wikipedia.gif"
                        alt="Wikipedia"
                        href="https://en.wikipedia.org"
                    />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/blender-scares-me.gif"
                        alt="Blender scares me"
                        href="https://www.blender.org/"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/potassium.gif" alt="Potassium" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/despite-everything.gif"
                        alt="Despite everything... it's still you"
                    />
                </div>
            </div>
        </PaperBlock>

