                />
                <Blinkie type="button" src="/blinkies/buttons/portal.jpg" alt="Portal" />
                <Blinkie type="button" src="/blinkies/buttons/nintendo-ds.jpg" alt="Nintendo DS" />
                <Blinkie type="button" src="/blinkies/buttons/nintendo-wii.gif" alt="Nintendo Wii" />
                <Blinkie
                    type="button"
                    src="/blinkies/buttons/steam.gif"
                    alt="Play with Steam"
                    href="https://store.steampowered.com/"
                />
                <Blinkie
                    type="button"
                    src="/blinkies/buttons/paint-dot-net.jpg"
