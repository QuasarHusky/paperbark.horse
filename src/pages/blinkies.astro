                <Blinkie type="stamp" src="/blinkies/stamps/mlp-loyalty.gif" alt="Loyalty" />
                <Blinkie type="stamp" src="/blinkies/stamps/fluttershy-yay.webp" alt="Fluttershy yay" />
                <Blinkie type="stamp" src="/blinkies/stamps/fluttershy-bop.gif" alt="Fluttershy bop" />
                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/rainbow-dash-dealwithit.png"
                    alt="Rainbow Dash: Deal with it"
                />
                <Blinkie type="stamp" src="/blinkies/stamps/rainbow-dash.png" alt="Rainbow Dash Sleeping" />
                <Blinkie type="stamp" src="/blinkies/stamps/applejack.gif" alt="Applejack" />
                <Blinkie type="stamp" src="/blinkies/stamps/derpy.png" alt="Derpy" />
                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/rd-aj-hoof-bump.gif"
                    alt="Rainbow & AJ hoof bump"
                />
                <Blinkie type="stamp" src="/blinkies/stamps/twipie-boop.gif" alt="Twipie boop" />
                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/startrix.png"
                    alt="Trixie and Starlight Glimmer"
                />
                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/pinkie-cross-my-heart.gif"
