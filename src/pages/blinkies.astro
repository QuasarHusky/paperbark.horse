                    <Blinkie type="blinkie" src="/blinkies/blinkies/rarity.gif" alt="Rarity" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/twilight-sparkle.gif"
                        alt="Twilight Sparkle"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/asexual-pride.gif" alt="Asexual Pride" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/i-love-my-trans-friends.gif"
                        alt="I love my trans friends!"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/mp3-lover.gif" alt="mp3 lover" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/cya-later-alligator.gif"
                        alt="Cya Later Alligator"
                    />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/i-heart-pizza-hut.gif"
                        alt="I Heart Pizza Hut"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/pizza-time.gif" alt="Pizza Time!!" />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/minecraft.gif" alt="Minecraft" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/minecraft-vegetarian.gif"
                        alt="Minecraft Vegetarian"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/i-love-snow.gif" alt="I love SNOW!!!!" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/smiling-friends.gif"
                        alt="Smiling Friends"
                    />
                    <Blinkie type="blinkie" src="/blinkies/blinkies/glep.gif" alt="Glep" />
                    <Blinkie
                        type="blinkie"
                        src="/blinkies/blinkies/pinkie-pie-smile-smile-smile.gif"
