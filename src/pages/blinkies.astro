                <Blinkie
                    type="button"
                    src="/blinkies/buttons/made-with-my-own-two-paws.jpg"
                    alt="Made with my own two paws"
                />
                <Blinkie
                    type="button"
                    src="/blinkies/buttons/neocities-delete-twitter.gif"
                    alt="Delete Twitter, make a Neocities"
                    href="https://neocities.org"
                />
                <Blinkie
                    type="button"
                    src="/blinkies/buttons/kris-where-tf-are-we.png"
                    alt="Kris where tf are we"
