                    alt="Ralsei & Kris splat"
                />

                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/wheatley-crab.gif"
                    alt="Wheatley Crab"
                    href="https://www.youtube.com/watch?v=v47zSNZcyPQ"
                />

                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/ashens.gif"
                    alt="ashens.com"
                    href="https://www.youtube.com/@ashens"
                />

                <Blinkie
                    type="stamp"
                    src="/blinkies/stamps/nerdcubed.png"
                    alt="NerdCubed Gaming"
                    href="https://www.youtube.com/@NerdCubed"
                />

                <Blinkie type="stamp" src="/blinkies/stamps/smiling-friends.gif" alt="Smiling Friends" />
                <Blinkie type="stamp" src="/blinkies/stamps/spongebob-gary.png" alt="Spongebob Gary" />
                <Blinkie type="stamp" src="/blinkies/stamps/pinkie-hey-squidward.gif" alt="Hey Squidward" />
                <Blinkie type="stamp" src="/blinkies/stamps/dogz.png" alt="Dogz" />
                <Blinkie type="stamp" src="/blinkies/stamps/windows-7.png" alt="Windows 7" />
                <Blinkie type="stamp" src="/blinkies/stamps/i-love-lua.png" alt="I Love Lua" />
                <Blinkie type="stamp" src="/blinkies/stamps/paint-dot-net.jpg" alt="I use Paint.NET" />
            </div>
        </PaperBlock>

        <PaperBlock>
            <Content theme="paper">
                <!-- TODO: Fix spacing -->
                <h2>Buttons</h2>
                <br />
            </Content>
            <div class="buttons-grid">
                <Blinkie type="button" src="/blinkies/buttons/pride-rainbow.png" alt="Rainbow pride flag" />
                <Blinkie type="button" src="/blinkies/buttons/pride-aroace.png" alt="Aroace pride flag" />
