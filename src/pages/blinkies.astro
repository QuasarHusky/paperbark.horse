                        alt="Pinkie Pie: Smile! Smile! Smile!"
                    />
                    <img src="/blinkies/blinkies/jerma985.gif" alt="Jerma985" />
                    <a
                        href="https://www.youtube.com/watch?v=ry-Z6_yfZoE"
                        target="_blank"
                        rel="noopener noreferrer"
