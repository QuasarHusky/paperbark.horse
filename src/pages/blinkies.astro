---
import PaperBlock from "$components/containers/PaperBlock.astro";
import Blinkie from "$components/elements/Blinkie.astro";
import Content from "$components/elements/Content.astro";
import SimpleLayout from "$components/layouts/SimpleLayout.astro";
import Page from "$layouts/Page.astro";
