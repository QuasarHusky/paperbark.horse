                <img src="/blinkies/buttons/nintendo-ds.jpg" alt="Nintendo DS" />
                <img src="/blinkies/buttons/nintendo-wii.gif" alt="Nintendo Wii" />
                <a href="https://store.steampowered.com/" target="_blank" rel="noopener noreferrer">
