---
interface Props {
    src: string;
    alt?: string;
    width?: string;
}

const { src, alt = "", width } = Astro.props;
---

<div class="polaroid" style={{ "--polaroid-width": width }}>
    <img {src} {alt} />
</div>

<style lang="scss">
    .polaroid {
        --polaroid-width: 12.5rem;
        --polaroid-edge: calc(var(--polaroid-width) * 0.05);

        position: relative;

        display: flex;
        flex-direction: column;

        width: var(--polaroid-width);
        aspect-ratio: 85 / 100;

        padding-top: var(--polaroid-edge);
        padding-left: var(--polaroid-edge);
        padding-right: var(--polaroid-edge);

        background-image: linear-gradient(-45deg, #f3f3f3, #ffffff);

        box-shadow: var(--shadow-medium);

        img {
            width: 100%;
            aspect-ratio: 1 / 1;
            object-fit: cover;
        }
    }
</style>
