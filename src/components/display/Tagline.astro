        // Quotes
        { type: "quote", text: "Hoof bump!" },
        { type: "quote", text: "Eeyup!" },
        { type: "quote", text: "20% cooler!" },
        { type: "quote", text: "The night will last forever!" },
        { type: "quote", text: "I just don't know what went wrong!" },
        { type: "quote", text: "What the dog doing?" },

        // Text
        { type: "text", text: "I &#9829; Vinyl Scratch!" },
        { type: "text", text: "I &#9829; Sunburst!" },
        { type: "text", text: "I &#9829; Big Mac!" },
        { type: "text", text: "I &#9829; Marble Pie!" },
        { type: "text", text: "Every pony is best pony!" },
    ];

    function refreshQuote() {
        let taglineText = document.getElementById("tagline-text");
        let taglineContainer = document.getElementById("tagline-container");

        if (!taglineText || !taglineContainer) return;

        let quote = quotes[Math.floor(Math.random() * quotes.length)];

        if (quote.type === "song") {
            taglineText.innerHTML = `&#9835;&nbsp;${quote.text}&nbsp;&#9835;`;
        } else if (quote.type === "quote") {
            taglineText.innerHTML = `&ldquo;${quote.text}&rdquo;`;
        } else {
            taglineText.innerHTML = quote.text;
        }

        if (quote.href) {
            taglineContainer.setAttribute("href", quote.href);
        } else {
            taglineContainer.removeAttribute("href");
        }
    }

    refreshQuote();

    const boopTarget = document.getElementById("boop-target");

    if (boopTarget) {
        boopTarget.addEventListener("click", refreshQuote);
    }
</script>

<style lang="scss">
    #tagline-text {
        max-width: 34ch;

        padding: 1rem 2.2rem;

        font-weight: var(--font-medium);
        text-align: center;
        text-wrap: balance;
    }
</style>
